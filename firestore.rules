rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net: Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Base digest documentation
    match /users/{userId}/digests/{digestId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 3. Subcollection for message log chunks
    match /users/{userId}/digests/{digestId}/messages/{chunkId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 4. Subcollection for deep file attachments
    match /users/{userId}/digests/{digestId}/attachments/{attachmentId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
